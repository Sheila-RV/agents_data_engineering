# --- LLM (optional!) ---------------------------------------------------------
# Lakekeeper runs fully WITHOUT an API key: agents fall back to a deterministic
# mock LLM. Set a key only if you want live Claude-powered agent decisions.
ANTHROPIC_API_KEY=

# Model used for agent decisions (supervisor, quality, transform, validation)
LLM_MODEL=claude-sonnet-5
# Cheaper model used for report generation
LLM_MODEL_CHEAP=claude-haiku-4-5

# Force mock mode even if an API key is set (1 = mock, 0 = auto)
LAKEKEEPER_MOCK_LLM=0

# --- Lakehouse ---------------------------------------------------------------
# Root directory for landing files and Delta tables (default: ./data)
LAKE_ROOT=./data
